{
  "name": "sigil-breaker",
  "version": "0.1.0",
  "description": "A mobile-first landscape Three.js FPS foundation built with TypeScript and Vite.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:cloudflare": "tsc && vite build --base=/",
    "deploy:cloudflare": "wrangler deploy",
    "preview": "vite preview",
    "prepare:pages": "node scripts/prepare-pages-dist.mjs",
    "preview:pages": "node scripts/serve-pages-preview.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "qa:headed:enemies": "npm run build && node scripts/run-headed-enemy-qa.mjs",
    "qa:headed:player-character": "node scripts/run-headed-player-character-qa.mjs",
    "qa:headed:player-viewmodel": "npm run build && node scripts/run-headed-player-viewmodel-qa.mjs",
    "pose:harness:player": "node scripts/run-player-pose-harness.mjs",
    "validate:browser": "npm run build && npm run prepare:pages && playwright test",
    "validate:assets": "node scripts/validate-assets.mjs",
    "validate:levels": "node scripts/validate-levels.mjs",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schulerj89/sigil-breaker.git"
  },
  "keywords": [
    "threejs",
    "fps",
    "mobile-game",
    "typescript",
    "vite"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/schulerj89/sigil-breaker/issues"
  },
  "homepage": "https://schulerj89.github.io/sigil-breaker/",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "@types/three": "^0.185.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.2.7",
    "vitest": "^4.0.16",
    "wrangler": "^4.107.0"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}
